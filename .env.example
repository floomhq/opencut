# OpenCut Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API key (used for transcription fallback and AI planning)
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs API key (used for text-to-speech voice generation)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Pexels API key (used for B-roll stock video fetching)
PEXELS_API_KEY=your_pexels_api_key_here

# Optional: API server port (default: 3000)
PORT=3000
